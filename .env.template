# Football Commentary System - Configuration File
# Copy this to .env and fill in your values

# ============================================================================
# Backend Selection
# ============================================================================

# Choose: ollama (recommended), openai, or huggingface
COMMENTARY_BACKEND=ollama

# ============================================================================
# OpenAI Configuration (if using OpenAI backend)
# ============================================================================

# Get from: https://platform.openai.com/account/api-keys
OPENAI_API_KEY=sk-your-key-here

# Model: gpt-4 (best quality), gpt-3.5-turbo (faster, cheaper)
OPENAI_MODEL=gpt-4

# Temperature (0.0-2.0): Lower = deterministic, Higher = creative
OPENAI_TEMPERATURE=0.9

# ============================================================================
# Ollama Configuration (if using Ollama backend)
# ============================================================================

# Ollama server address
OLLAMA_HOST=http://localhost:11434

# Model: mistral (recommended), neural-chat, orca-mini, llama2
OLLAMA_MODEL=mistral

# ============================================================================
# Hugging Face Configuration (if using Hugging Face)
# ============================================================================

# Model from Hub: gpt2, mistralai/Mistral-7B, meta-llama/Llama-2-7b-chat
HF_MODEL_NAME=gpt2

# Device: cuda (GPU), cpu
HF_DEVICE=cuda

# ============================================================================
# Video Input Configuration
# ============================================================================

# Source: 0 (webcam), "path/to/file.mp4", "rtsp://..." (IP camera)
VIDEO_SOURCE=0

# Resolution for processing (lower = faster): 640x480, 960x540, 1280x720
VIDEO_RESOLUTION=1280x720

# Target FPS (limit processing speed)
TARGET_FPS=25

# ============================================================================
# Team Configuration
# ============================================================================

# Team names
HOME_TEAM=Manchester United
AWAY_TEAM=Liverpool

# ============================================================================
# Object Detection Configuration
# ============================================================================

# YOLO model size: nano (fastest), small (good balance), medium, large
YOLO_MODEL_SIZE=small

# Detection confidence threshold (0.0-1.0): Lower = more detections
DETECTION_CONFIDENCE=0.5

# ============================================================================
# Commentary Generation Configuration  
# ============================================================================

# Minimum seconds between commentary pieces (avoid too frequent)
MIN_COMMENTARY_INTERVAL=1.5

# Minimum action confidence to generate commentary (0.0-1.0)
MIN_ACTION_CONFIDENCE=0.7

# Commentary style preference (context for LLMs)
COMMENTARY_STYLE=Peter Drury

# ============================================================================
# Voice/Audio Configuration
# ============================================================================

# Enable voice synthesis
ENABLE_VOICE=true

# Voice model: en-GB-ThomasNeural (Peter Drury style), en-US-BrianNeural, etc.
VOICE_MODEL=en-GB-ThomasNeural

# Speech rate (0.5-2.0): 1.0 = normal speed
SPEECH_RATE=1.0

# ============================================================================
# Visualization & Display
# ============================================================================

# Show video display window
ENABLE_VISUALIZATION=true

# Show real-time stats overlay
SHOW_STATS=true

# Display player IDs
SHOW_PLAYER_IDS=true

# Display action confidence scores
SHOW_CONFIDENCE=true

# ============================================================================
# Performance Tuning
# ============================================================================

# Use GPU acceleration (requires CUDA)
USE_GPU=true

# Number of worker threads for processing
NUM_WORKERS=4

# Max frame queue size (buffer between capture and processing)
FRAME_QUEUE_SIZE=10

# Max commentary queue size
COMMENTARY_QUEUE_SIZE=5

# ============================================================================
# Logging & Analytics
# ============================================================================

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Enable analytics logging to database
ENABLE_ANALYTICS=true

# Analytics database path
ANALYTICS_DB=football_analytics.db

# ============================================================================
# API Server Configuration (if running as server)
# ============================================================================

# Enable REST API server
ENABLE_API_SERVER=false

# API server host and port
API_HOST=0.0.0.0
API_PORT=5000

# ============================================================================
# Streaming Configuration (for broadcasting)
# ============================================================================

# Enable streaming output
ENABLE_STREAMING=false

# Streaming server host and port
STREAM_HOST=0.0.0.0
STREAM_PORT=8000

# NDI stream name (if using NDI)
NDI_STREAM_NAME=Football Commentary

# ============================================================================
# Docker/Cloud Configuration
# ============================================================================

# Container mode (set automatically in Docker)
CONTAINER_MODE=false

# Cloud credentials (AWS, GCP, etc.)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# ============================================================================
# Advanced Options
# ============================================================================

# Debug mode (verbose logging, extra checks)
DEBUG_MODE=false

# Profile performance (slow but detailed timing)
PROFILE_PERFORMANCE=false

# Save processed frames to disk
SAVE_FRAMES=false

# Save directory for frames/videos
OUTPUT_DIR=./output

# Match metadata
MATCH_ID=001
LEAGUE=Premier League
SEASON=2023-24
